#!/bin/sh

# Configuration
CACHE_FILE="/tmp/i3_useless_fact.txt"
CACHE_TIME=300 # 5 minutes
MAX_LEN=255     # Max characters allowed on i3bar before cutting off with "..."
COLORS=("#FF9F00" "#FF5E00" "#FF3366" "#FF66B2" "#E066FF" "#A370FF" "#33CCFF" "#10F0A0" "#39FF14" "#CCFF00" "#FFE600")

get_random_color() {
    printf "%s" "${COLORS[$((RANDOM % ${#COLORS[@]}))]}"
}

# Helper to cleanly truncate text and append "..." if it exceeds MAX_LEN
truncate_text() {
    local text="$1"
    if [ ${#text} -gt $MAX_LEN ]; then
        # Subtract 3 from MAX_LEN to account for the "..."
        printf "%s..." "$(echo "$text" | cut -c 1-$((MAX_LEN - 3)))"
    else
        printf "%s" "$text"
    fi
}

# --- API Fetchers ---

fetch_useless_fact() {
    local raw status body res
    raw=$(curl -s --max-time 3 --write-out "\n%{http_code}" "https://uselessfacts.jsph.pl/api/v2/facts/random?language=en")
    status=$(echo "$raw" | tail -n 1)
    body=$(echo "$raw" | sed '$d')

    if [ "$status" -ne 200 ] || [ -z "$body" ]; then
        printf "[Fact] Conn Err (%s)" "$status"
        return 1
    fi
    res=$(echo "$body" | jq -e -r '.text' 2>/dev/null)
    if [ $? -ne 0 ] || [ -z "$res" ]; then
        printf "[Fact] JSON Err"
        return 1
    fi
    printf "[Fact] %s" "$res"
}

