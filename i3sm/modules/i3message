# --- Main Logic ---

fetch_needed=0
if [ ! -f "$CACHE_FILE" ] || [ $(($(date +%s) - $(date -r "$CACHE_FILE" +%s))) -gt $CACHE_TIME ]; then
    fetch_needed=1
fi

if [ $fetch_needed -eq 1 ]; then
    fetchers=("fetch_useless_fact" "fetch_joke" "fetch_cat_fact" "fetch_advice" "fetch_chuck" "fetch_dev_joke")
    
    random_index=$((RANDOM % ${#fetchers[@]}))
    selected_fetcher="${fetchers[$random_index]}"
    
    # Capture the output AND the exit status of the fetcher
    raw_fact=$($selected_fetcher)
    fetch_status=$?
    
    if [ $fetch_status -eq 0 ] && [ -n "$raw_fact" ] && [ "$raw_fact" != "null" ]; then
        # Success: Format, Cache, and Display
        cleaned_fact=$(echo "$raw_fact" | tr '\n' ' ' | tr -d '\r' | sed 's/"/\\"/g' | sed 's/  */ /g')
        message=$(truncate_text "$cleaned_fact")
        color=$(get_random_color)
        
        echo "$color|$message" > "$CACHE_FILE"
    else
        # Error: Display the error but DO NOT save to cache file
        message="${raw_fact:-[API Fetch Failed]}"
        color="#FF0000" # Red indicator for errors
    fi
else
    # Valid cache exists, read from it
    if [ -f "$CACHE_FILE" ]; then
        cached_data=$(cat "$CACHE_FILE")
        color=$(echo "$cached_data" | cut -d'|' -f1)
        message=$(echo "$cached_data" | cut -d'|' -f2-)
    fi
fi

# Failsafe if everything is empty
[ -z "$color" ] && color="#FF9F00"
[ -z "$message" ] && message="Caffeine Overflow"

echo "{ \"full_text\": \"$message\", \"color\": \"$color\" },"
